<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Cybersecurity Awareness Chatbot"
        Height="720" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Sidebar button style -->
        <Style x:Key="SideBtn" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════ SIDEBAR ═══════════ -->
        <DockPanel Grid.Column="0" Background="#181825" LastChildFill="False">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="🤖 CyberBot" Foreground="#CBA6F7" FontSize="20"
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,22,0,14"/>
                <Separator Background="#313244" Margin="12,0,12,8"/>
                <Button x:Name="BtnChat"  Content="💬   Chat"         Style="{StaticResource SideBtn}" Click="BtnChat_Click"/>
                <Button x:Name="BtnTasks" Content="✅   Task Manager" Style="{StaticResource SideBtn}" Click="BtnTasks_Click"/>
                <Button x:Name="BtnQuiz"  Content="📝   Quiz"         Style="{StaticResource SideBtn}" Click="BtnQuiz_Click"/>
                <Button x:Name="BtnLog"   Content="📋   Activity Log" Style="{StaticResource SideBtn}" Click="BtnLog_Click"/>
                <Separator Background="#313244" Margin="12,10"/>
                <TextBlock Text="💡 Tips:" Foreground="#CBA6F7" FontSize="12"
                           FontWeight="SemiBold" Margin="14,0,0,4"/>
                <TextBlock Foreground="#6C7086" FontSize="11" Margin="14,0,14,0"
                           TextWrapping="Wrap"
                           Text="• Type 'help' in chat&#10;• 'Add task - ...'&#10;• 'Remind me in X days'&#10;• 'Show activity log'&#10;• 'Start quiz'"/>
            </StackPanel>
        </DockPanel>

        <!-- ═══════════ MAIN AREA ═══════════ -->
        <Grid Grid.Column="1">

            <!-- ── CHAT PANEL ── -->
            <Grid x:Name="ChatPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="62"/>
                </Grid.RowDefinitions>

                <Border Background="#313244" Grid.Row="0">
                    <TextBlock Text="💬  Chat with CyberBot" Foreground="White"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0"/>
                </Border>

                <ScrollViewer x:Name="ChatScroll" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel x:Name="ChatStack"/>
                </ScrollViewer>

                <Grid Grid.Row="2" Background="#181825">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Grid.Column="0"
                             Style="{StaticResource InputBox}"
                             Margin="12,12,6,12"
                             KeyDown="ChatInput_KeyDown"/>
                    <Button Grid.Column="1" Content="Send"
                            Background="#CBA6F7" Style="{StaticResource ActionBtn}"
                            Margin="0,12,12,12" Click="BtnSend_Click"/>
                </Grid>
            </Grid>

            <!-- ── TASK PANEL ── -->
            <Grid x:Name="TasksPanel" Visibility="Collapsed" Background="#1E1E2E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <Border Background="#313244" Grid.Row="0">
                    <TextBlock Text="✅  Task Manager" Foreground="White"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0"/>
                </Border>

                <!-- Add Task Form -->
                <Border Grid.Row="1" Background="#181825" CornerRadius="0" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Add New Task" Foreground="#CBA6F7"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtTaskTitle" Grid.Column="0"
                                     Style="{StaticResource InputBox}"
                                     Margin="0,0,6,0" Tag="Task title (e.g. Enable 2FA)"/>
                            <TextBox x:Name="TxtTaskDesc" Grid.Column="1"
                                     Style="{StaticResource InputBox}"
                                     Margin="6,0,0,0" Tag="Description"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtReminder" Grid.Column="0"
                                     Style="{StaticResource InputBox}"
                                     Margin="0,0,6,0" Tag="Reminder (e.g. in 3 days, tomorrow)"/>
                            <Button Content="➕  Add Task"
                                    Background="#A6E3A1" Style="{StaticResource ActionBtn}"
                                    Width="120" Grid.Column="1" Click="BtnAddTask_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Task List -->
                <ListView x:Name="TaskListView" Grid.Row="2"
                          Background="Transparent" Foreground="White"
                          FontSize="13" Margin="12,8,12,0" BorderThickness="0"/>

                <!-- Task Actions -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0">
                    <Button Content="✔  Complete" Background="#89B4FA"
                            Style="{StaticResource ActionBtn}" Width="120"
                            Margin="0,0,10,0" Click="BtnCompleteTask_Click"/>
                    <Button Content="🗑  Delete" Background="#F38BA8"
                            Style="{StaticResource ActionBtn}" Width="100"
                            Click="BtnDeleteTask_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── QUIZ PANEL ── -->
            <Grid x:Name="QuizPanel" Visibility="Collapsed" Background="#1E1E2E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#313244" Grid.Row="0">
                    <TextBlock Text="📝  Cybersecurity Quiz" Foreground="White"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="QuizContent" Margin="32,20">
                        <TextBlock x:Name="TxtQuizStatus" Foreground="#CBA6F7"
                                   FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtQuizQuestion" Foreground="White"
                                   FontSize="17" FontWeight="SemiBold"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <StackPanel x:Name="QuizOptionsPanel"/>
                        <TextBlock x:Name="TxtQuizFeedback" FontSize="14"
                                   TextWrapping="Wrap" Margin="0,16,0,0"
                                   Visibility="Collapsed"/>
                        <Button x:Name="BtnStartQuiz" Content="▶  Start Quiz"
                                Background="#CBA6F7" Style="{StaticResource ActionBtn}"
                                Width="150" HorizontalAlignment="Left"
                                Margin="0,20,0,0" Click="BtnStartQuiz_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── LOG PANEL ── -->
            <Grid x:Name="LogPanel" Visibility="Collapsed" Background="#1E1E2E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <Border Background="#313244" Grid.Row="0">
                    <TextBlock Text="📋  Activity Log" Foreground="White"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0"/>
                </Border>

                <ListBox x:Name="LogListBox" Grid.Row="1"
                         Background="Transparent" Foreground="#CDD6F4"
                         FontFamily="Consolas" FontSize="12"
                         Margin="14,10" BorderThickness="0"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0">
                    <Button Content="🗑  Clear Log" Background="#F38BA8"
                            Style="{StaticResource ActionBtn}" Width="120"
                            Click="BtnClearLog_Click"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Window>